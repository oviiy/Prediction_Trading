# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# --- Polymarket (for --broker polymarket) ---
# Get these from polymarket.com → Account → API
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# Wallet private key on Polygon (0x...)
POLY_PRIVATE_KEY=

# --- Kalshi (for --broker kalshi) ---
# Get key ID from kalshi.com → Account → API Keys
KALSHI_API_KEY_ID=
# Path to the PEM private key file downloaded from Kalshi
KALSHI_PRIVATE_KEY_PATH=